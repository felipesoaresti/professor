# =========================
# 🌍 Aplicação
# =========================
APP_NAME=meu-app
APP_ENV=development
APP_PORT=8080
APP_DEBUG=true

# =========================
# 🗄️ Banco de Dados (Postgres)
# =========================
DB_HOST=postgres-svc
DB_PORT=5432
DB_NAME=meubanco
DB_USER=admin
DB_PASSWORD=SuperSenha123

# =========================
# ⚡ Redis / Cache
# =========================
REDIS_HOST=redis-svc
REDIS_PORT=6379

# =========================
# 🔐 Segurança / Tokens
# =========================
JWT_SECRET=meu_token_super_secreto
JWT_EXPIRATION=3600

# =========================
# 🌐 URLs internas (K8s DNS)
# =========================
API_URL=http://meu-app-svc.default.svc.cluster.local
DB_URL=postgres://admin:SuperSenha123@postgres-svc:5432/meubanco

# =========================
# 📦 Configuração Kubernetes
# =========================
NAMESPACE=default
REPLICAS=2

# =========================
# 🧪 Feature Flags
# =========================
FEATURE_X_ENABLED=true
FEATURE_Y_ENABLED=false
